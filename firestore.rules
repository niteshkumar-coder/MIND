// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: appointments
// Document ID: {appointmentId}
// Fields:
//   - fullName: string (required) - Patient's full name
//   - mobileNumber: string (required) - Patient's mobile number
//   - appointmentDate: string (required) - Date of appointment
//   - appointmentTime: string (required) - Time of appointment
//   - problem: string (optional) - Patient's problem/message
//   - status: string (required) - Appointment status (pending/completed)
//   - createdAt: timestamp (required) - Creation timestamp
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidAppointment(data) {
      return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.mobileNumber is string && data.mobileNumber.size() >= 10 && data.mobileNumber.size() <= 20 &&
             data.appointmentDate is string &&
             data.appointmentTime is string &&
             data.status in ['pending', 'completed'] &&
             data.createdAt is timestamp &&
             (!('problem' in data) || (data.problem is string && data.problem.size() < 1000));
    }

    match /appointments/{appointmentId} {
      // Allow anyone to create an appointment (public booking)
      allow create: if isValidAppointment(request.resource.data);
      
      // PUBLIC ACCESS WORKAROUND
      // Due to environment restrictions with Firebase Auth (unauthorized-domain / admin-restricted-operation),
      // we are allowing public access to manage appointments. 
      // WARNING: In a production environment, this should be restricted with proper Auth.
      allow read, list, update, delete: if true;
    }
  }
}
